{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run PowerShell Script",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$default",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Run Pester Tests",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", "Invoke-Pester -Path ${file} -PassThru"],
      "problemMatcher": "$default",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Format PowerShell File",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", "Invoke-Formatter -Path ${file}"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Analyze PowerShell Script",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", "Invoke-ScriptAnalyzer -Path ${file}"],
      "problemMatcher": "$default",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
